<odoo>
  <record id="view_product_form_webextras" model="ir.ui.view">
    <field name="name">product.template.form.webextras</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_only_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//notebook" position="inside">
        <page string="Site Web (Extras)" name="website_webextras">
          <group string="Contenu site web">
            <field name="web_description" widget="html"/>
            <separator string="Fiche technique"/>
            <field name="tech_sheet_pdf" filename="tech_sheet_filename"/>
            <field name="tech_sheet_filename" placeholder="fiche-technique.pdf"/>
            <separator string="Galerie d’images"/>
            <field name="gallery_attachment_ids" widget="many2many_binary"/>
          </group>
        </page>
      </xpath>
    </field>
  </record>
</odoo>
