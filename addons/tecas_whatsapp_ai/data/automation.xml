<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        TECAS WhatsApp AI - Automation trigger
        ===============================================================
        Fires on every new inbound whatsapp.message and delegates to
        the Python handler, which verifies the account phone number,
        calls Claude, and either auto-replies or escalates to a salesman.

        Post-install configuration required (Settings > Technical > System Parameters):
          ai.openai_key                           - OpenAI API key (must already exist in DB)
          tecas_whatsapp_ai.salesman_ids          - comma-separated res.users IDs, e.g. "5,8,12,15,20"
          tecas_whatsapp_ai.last_salesman_index   - auto-managed round-robin counter (seed: -1)
    -->
    <data noupdate="1">

        <!-- Server action executed by the automation -->
        <record id="action_server_whatsapp_ai" model="ir.actions.server">
            <field name="name">TECAS WhatsApp AI - Traitement message entrant</field>
            <field name="model_id" model="ir.model" search="[('model', '=', 'whatsapp.message')]"/>
            <field name="state">code</field>
            <field name="code">env['tecas.whatsapp.ai'].handle_incoming_message(record.id)</field>
        </record>

        <!-- Automation rule: triggers on every newly created inbound message -->
        <record id="automation_whatsapp_ai" model="base.automation">
            <field name="name">TECAS WhatsApp AI - Messages entrants Service Commercial</field>
            <field name="model_id" model="ir.model" search="[('model', '=', 'whatsapp.message')]"/>
            <field name="trigger">on_create</field>
            <!-- Pre-filter: only process inbound messages (outbound are our own replies) -->
            <field name="filter_domain">[("message_type", "=", "inbound")]</field>
            <field name="action_server_ids" eval="[(4, ref('action_server_whatsapp_ai'))]"/>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
