    <record id="paperformat_a5" model="report.paperformat">
        <field name="name">A5 Paper Format</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">297</field> <!-- A5 height in mm -->
        <field name="page_width">210</field> <!-- A5 width in mm -->
