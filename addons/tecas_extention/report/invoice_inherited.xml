<odoo>
    <template id="report_invoice_document_inherit" inherit_id="account.report_invoice_document">
        <xpath expr="//t[@t-if='o.tax_totals'][@t-call='account.document_tax_totals']" position="after">
            <t t-if="o.cash">
                <tr class="o_total">
                    <td><strong>Frais de Timbre</strong></td>
                    <td class="text-end">
                        <span t-out="o.stamp_duty"
                              t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                    </td>
                </tr>
                <tr>
                    <td><strong>Net à Payer</strong></td>
                    <td class="text-end">
                        <span t-out="o.net_to_pay"
                              t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                    </td>
                </tr>
            </t>
        </xpath>
        <xpath expr="//p[@name='payment_communication']" position="before">
            <t t-if="o.cash">
                <p class="text-muted">
                    Droit de timbre payé sur états <br/> (décision n°_83 du 1_3_83)
                </p>
            </t>
        </xpath>
    </template>
</odoo>