<odoo>
    <record id="view_move_form_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit.cash</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="cash" readonly="state != 'draft'" string="Espèce ?" widget="custom_boolean_toggle_confirm" force_save="1"/>
                <field name="stamp_duty" string="Timbre" invisible="True"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Split Invoices" invisible="move_type != 'out_invoice'">
                    <group>
                        <group>
                            <field name="parent_invoice_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="child_invoice_ids" readonly="1" nolabel="1">
                                <list>
                                    <field name="name"/>
                                    <field name="invoice_date"/>
                                    <field name="amount_total"/>
                                </list>
                            </field>
                        </group>
                    </group>
                </page>
            </xpath>
            <xpath expr="//button[@name='open_created_caba_entries']" position="after">
                <button type="object"
                        name="action_view_split_invoices"
                        string="Split Invoices"
                        class="oe_stat_button"
                        icon="fa-files-o"
                        invisible="split_invoice_count == 0">
                    <field name="split_invoice_count" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
